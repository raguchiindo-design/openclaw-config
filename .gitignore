# GitClaw - OpenClaw Workspace Backup
# 排除敏感和临时文件

# 环境变量和密钥
.env
.env.*
*.key
*.pem
*.token
*.secret
credentials/
identity/

# 临时文件
tmp/
temp/
*.tmp
*.temp

# 系统配置文件（不备份，不同环境不同）
crontab
crontab.bak
openclaw.json.backup
openclaw.json.bak*
openclaw.json.manual-backup

# 日志和输出
logs/
clawbot-outputs/
*.log

# 浏览器缓存和会话
browser/
canvas/

# 任务执行状态
state/
completions/

# 媒体文件（大文件，不备份）
media/

# 其他 Git 目录（避免嵌套）.openclaw 本身不该在 workspace 下
.openclaw/.git

# 本地测试文件
bash
cat
cd
chmod
cr
echo
find
generate_result_*.py

# 编辑器备份
*.swp
*.swo
*~
.DS_Store
